# nl-db provider API keys. Copy this file to .env and fill in the keys
# for whichever provider you plan to use. nl-db only reads the key for the
# provider selected in ~/.config/nl-db/config.toml (or via NL_DB_PROVIDER).

# Anthropic — used when provider = "anthropic"
ANTHROPIC_API_KEY=

# OpenAI — used when provider = "openai"
OPENAI_API_KEY=

# OpenAI-compatible endpoints (Apple Intelligence shim, Ollama, vLLM, etc.)
# Used when provider = "openai_compatible". Many local servers don't require
# a real key — leave blank or set to a placeholder.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8080/v1
